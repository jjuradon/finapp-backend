# .env.example

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string for the main application database.
DATABASE_URL=postgresql+asyncpg://finapp:changeme@localhost:5432/finapp

# ── Authentication ────────────────────────────────────────────────────────────
# RS256 private key for JWT signing. Generate with: openssl genrsa 2048
# Store the full PEM block as a single line with \n replacing newlines.
AUTH_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nCHANGEME\n-----END RSA PRIVATE KEY-----

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection URL. Used for login rate-limiting and token blacklist.
REDIS_URL=redis://localhost:6379/0

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# RabbitMQ AMQP connection string. Used for async event publishing.
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Application ───────────────────────────────────────────────────────────────
# Human-readable service name included in every structured log line.
SERVICE_NAME=finapp-backend

# Log level. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Set to "development" or "production". Controls debug mode and CORS origins.
ENVIRONMENT=development
